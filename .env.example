NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DASHSCOPE_API_KEY=sk-xxx

# ASR
ALIYUN_REALTIME_ASR_MODEL=qwen3-asr-flash-realtime
ALIYUN_REALTIME_ASR_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ALIYUN_REALTIME_ASR_SILENCE_DURATION_MS=1200

# Live coach
ALIYUN_OMNI_COACH_MODEL=qwen3.5-omni-flash-realtime
ALIYUN_OMNI_COACH_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ALIYUN_OMNI_COACH_SILENCE_DURATION_MS=2000
ALIYUN_OMNI_BODY_AUDIO_WINDOW_MS=500

# QA realtime interviewer
ALIYUN_QA_OMNI_MODEL=qwen3.5-omni-plus-realtime
ALIYUN_QA_OMNI_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ALIYUN_QA_OMNI_VAD_THRESHOLD=0.4
ALIYUN_QA_OMNI_MAX_TOKENS=512
ALIYUN_QA_OMNI_TEMPERATURE=0.6
ALIYUN_QA_OMNI_BOOTSTRAP_SILENCE_MS=240

# QA pacing
QA_PREWARM_INTERVAL_SECONDS=20
QA_PREWARM_TRIGGER_DELAY_MS=1500
QA_PREWARM_MIN_CHARS=120
QA_AUTO_ADVANCE_DELAY_MS=1200
QA_RESPONSE_DONE_AUDIO_GRACE_MS=1200
QA_SILENCE_FALLBACK_DELAY_MS=10000
QA_PREWARM_MIN_DELTA_CHARS=40
QA_MAX_QUESTION_TOPICS=3
QA_MAX_FOLLOW_UPS_PER_QUESTION=3
ALIYUN_QA_BRAIN_TIMEOUT_SECONDS=15

# Report
REPORT_WINDOW_BUILD_INTERVAL_SECONDS=120
REPORT_WINDOW_MIN_MS=180000
ALIYUN_REPORT_WINDOW_MODEL=qwen-plus-latest
ALIYUN_REPORT_BRAIN_MODEL=qwen-plus-latest
ALIYUN_REPORT_BRAIN_FALLBACK_MODEL=qwen-max-latest
ALIYUN_REPORT_WINDOW_TIMEOUT_SECONDS=30
ALIYUN_REPORT_BRAIN_TIMEOUT_SECONDS=45
REPORT_REASSURANCE_AUDIO_TIMEOUT_SECONDS=12
